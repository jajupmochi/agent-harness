{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/hooks/review-gate/track.sh\"", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "if": "Bash(git commit *)", "command": "\"$HOME/.claude/hooks/review-gate/precommit.sh\"", "timeout": 10 },
          { "type": "command", "if": "Bash(git push *)", "command": "\"$HOME/.claude/hooks/review-gate/precommit.sh\"", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/hooks/review-gate/gate.sh\"", "timeout": 60, "statusMessage": "review-gate: reviewing changes..." }
        ]
      }
    ]
  }
}
