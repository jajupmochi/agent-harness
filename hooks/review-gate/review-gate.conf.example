# review-gate config.  Copy to review-gate.conf (next to the hook scripts) to override defaults.
#
# block_commit: 0 = `git commit` is free (DEFAULT — the AI review at Stop still runs and surfaces
#                   findings, it just never blocks committing);
#               1 = also DENY commits, the same NON-FATAL way as push (denies the commit command but
#                   the agent continues its other work; you/the user commit manually).
# Asked once at first autopilot setup; default is 0 (do not block commits).
block_commit=0
#
# stop_mode: how the Stop-hook review is delivered. EVERY mode below still blocks/forces one review round
# (the review is always ENFORCED) — the modes only pick the LABEL Claude Code shows.
#   auto     = DEFAULT. Version-adaptive so you get enforced + no "error" label on EVERY version:
#              on Claude Code >= 2.1.152 it uses `hookSpecificOutput.additionalContext` (blocks AND is
#              shown as "Stop hook feedback", not an error — per the 2.1.152 release notes); on older
#              versions it uses `decision:block` (which those versions already display as feedback).
#              (Version is detected via `claude --version`, cached ~1 day.)
#   feedback = force the additionalContext path (clean "feedback" label). Needs CC >= 2.1.152, otherwise
#              the Stop is NOT blocked (review skipped) — only use if you know your version supports it.
#   block    = force the decision:block path (always blocks). On CC >= 2.1.174 this shows as
#              "Stop hook error:" (cosmetic — the review still runs). Use only if additionalContext ever
#              misbehaves for you.
stop_mode=auto
