{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/agent-harness/hooks/typecheck-on-edit/typecheck.sh\"",
            "timeout": 120,
            "statusMessage": "Typecheck (tsc) + prettier..."
          }
        ]
      }
    ]
  }
}
