{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/hooks/task-ledger/capture.sh\"", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/hooks/task-ledger/gate.sh\"", "timeout": 30, "statusMessage": "task-ledger: checking the round is finished..." }
        ]
      }
    ]
  }
}
