{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/agent-harness/hooks/ssh-guard/ssh-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking for SSH username-probing..."
          }
        ]
      }
    ]
  }
}
