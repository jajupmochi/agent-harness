{
  "name": "agent-harness",
  "version": "0.1.0",
  "description": "Curated Claude Code configuration: workflow rules, skills, hooks, plugin recommendations, tooling preferences, and project templates. Run /init-agent-harness in any project to scaffold it.",
  "bin": {
    "agent-harness": "./bin/install.js",
    "agent-harness-init": "./bin/install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://github.com/jajupmochi/agent-harness#readme",
  "bugs": {
    "url": "https://github.com/jajupmochi/agent-harness/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jajupmochi/agent-harness.git"
  },
  "keywords": [
    "claude-code",
    "claude",
    "skills",
    "hooks",
    "scaffold",
    "config",
    "workflow",
    "rules",
    "templates"
  ],
  "files": [
    "bin/",
    "rules/",
    "skills/",
    "hooks/",
    "recommendations/",
    "tooling/",
    "templates/",
    "setup/",
    "docs/",
    "scripts/",
    "adapters/",
    "codex/",
    "build.mjs",
    ".claude/",
    ".claude-plugin/",
    "hooks.json",
    ".codex-plugin/",
    "opencode.json",
    ".opencode/",
    "README.md",
    "README.zh.md",
    "USAGE.md",
    "USAGE.zh.md",
    "INVENTORY.md",
    "INVENTORY.zh.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "check:manifests": "node build.mjs --check",
    "test:projection": "node adapters/test-projection.mjs",
    "test:opencode-review": "node .opencode/plugin/review-gate.test.mjs",
    "test:deploy-skills": "node bin/deploy-skills.test.mjs",
    "test:models": "node scripts/test_resolve_model.mjs",
    "test:codex-install": "node scripts/install-codex-local.test.js",
    "deploy:skills": "node bin/deploy-skills.mjs",
    "install:codex": "node scripts/install-codex-local.js",
    "verify:codex": "node scripts/verify-codex-adapter.js && node scripts/test_resolve_model.mjs && node scripts/install-codex-local.test.js && bash scripts/test_codex_ruff_format_on_edit.sh && bash scripts/test_codex_review_gate.sh",
    "activate:codex": "node scripts/install-codex-local.js",
    "update:codex": "node scripts/codex-update-safe.js",
    "repair:codex-update": "node scripts/codex-update-safe.js --repair-cache"
  }
}
